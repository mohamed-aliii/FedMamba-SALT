# FedMamba-SALT Clinical Platform — Environment Variables
# Copy this file to .env and fill in all values.

# --- Database ---
DATABASE_URL=postgresql://fedmamba:changeme@postgres:5432/fedmamba
# For local dev without Docker, use SQLite:
# DATABASE_URL=sqlite:///./dev.db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Security ---
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# --- CORS ---
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Research Codebase Paths ---
# Absolute path to the repository root (parent of platform/)
RESEARCH_ROOT=/path/to/FedMamba
# Directory where research scripts write checkpoints and results
FL_OUTPUT_DIR=/path/to/FedMamba/output

# --- Postgres (used by docker-compose) ---
POSTGRES_PASSWORD=changeme
